<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Application Metadata -->
	<key>CFBundleDevelopmentRegion</key>
	<string>pt_BR</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.almaapp.oficial</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Alma</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Supported Device Types -->
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<!-- iPhone -->
		<integer>2</integer>
		<!-- iPad -->
	</array>

	<!-- Supported Orientations -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientationsIpad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Minimum OS Version -->
	<key>MinimumOSVersion</key>
	<string>14.0</string>

	<!-- App Features & Privacy -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Alma precisa de acesso à rede local para melhor sincronização.</string>
	<key>NSBonjourServiceTypes</key>
	<array>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
	</array>

	<!-- Permissions for CICLO 2 (commented for now) -->
	<!-- Will be uncommented in CICLO 2: Biometric Onboarding -->
	<!--
	<key>NSHealthShareUsageDescription</key>
	<string>Alma precisa acessar seus dados de saúde para oferecer recomendações personalizadas.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Alma usa sua localização para sugerir meditações e práticas contextualizadas.</string>
	<key>NSNotificationCenterUsageDescription</key>
	<string>Alma enviará notificações para lembrar você sobre suas práticas diárias.</string>
	-->

	<!-- Status Bar -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDarkContent</string>

	<!-- App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<key>127.0.0.1</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Launch Screen -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- Font Configuration (for custom fonts if added) -->
	<key>UIAppFonts</key>
	<array/>

	<!-- Note: Google Sign-In URL scheme will be added in CICLO 2 -->
	<!-- CFBundleURLTypes for Google Sign-In will be configured via Xcode -->
</dict>
</plist>
