# Appfile — app identifiers for fastlane
# https://docs.fastlane.tools/advanced/Appfile/

app_identifier("com.almaapp.app")    # iOS Bundle ID
apple_id(ENV["APPLE_ID"])            # Your Apple ID email (stored as env var)

# Google Play service account
json_key_file(ENV["GOOGLE_PLAY_KEY_FILE"])    # path to service-account.json locally
# or set SUPPLY_JSON_KEY_DATA env var in CI
