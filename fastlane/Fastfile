# ─────────────────────────────────────────────────────────────────────────────
#  Fastfile — Alma App automation
#
#  Usage:
#    bundle exec fastlane ios ci_beta       → CI: build + TestFlight
#    bundle exec fastlane ios beta          → build + TestFlight
#    bundle exec fastlane ios release       → build + App Store
#    bundle exec fastlane android beta      → build + Play Internal
#    bundle exec fastlane android release   → build + Play Production
# ─────────────────────────────────────────────────────────────────────────────

default_platform(:ios)

# ══ iOS ═══════════════════════════════════════════════════════════════════════

platform :ios do

  desc "CI: Build and upload to TestFlight"
  lane :ci_beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILE"],
      duration:     1200,
      in_house:     false
    )

    # Revoke any existing iOS Distribution certificates to free up quota.
    # These are orphaned certs from previous CI runs — their private keys
    # no longer exist, so they are unusable. Revoking them makes room for
    # a fresh certificate below.
    begin
      existing_certs = Spaceship::ConnectAPI::Certificate.all(
        filter: { certificateType: "IOS_DISTRIBUTION" }
      )
      existing_certs.each do |c|
        UI.message("Revoking orphaned Distribution cert: #{c.display_name} (#{c.id})")
        Spaceship::ConnectAPI.delete_certificate(certificate_id: c.id)
      end
    rescue => e
      UI.important("Could not revoke existing certs (non-fatal): #{e.message}")
    end

    # Create a signing keychain with a NON-EMPTY password.
    # Empty-password keychains cause 'security set-key-partition-list' to fail
    # silently on macOS 14, leaving the private key inaccessible to codesign.
    create_keychain(
      name:               "signing",
      password:           "gh-actions-signing",
      default_keychain:   false,
      unlock:             true,
      timeout:            3600,
      add_to_search_list: true
    )

    # Download or create an Apple Distribution certificate and install it
    # into the signing keychain. generate_apple_certs: true uses openssl to
    # generate the CSR locally — required for headless CI on macOS 12+.
    cert(
      api_key:              api_key,
      keychain_path:        File.expand_path("~/Library/Keychains/signing-db"),
      keychain_password:    "gh-actions-signing",
      generate_apple_certs: true
    )

    sigh(
      api_key:        api_key,
      app_identifier: "com.almaapp.app",
      force:          true
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "Alma.App.Oficial.xcodeproj"
    )

    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      project:     "Alma.App.Oficial.xcodeproj",
      scheme:      "Alma.App.Oficial (iOS)",
      destination: "platform=iOS Simulator,name=iPhone 15"
    )
  end

  desc "Build and upload to TestFlight (beta)"
  lane :beta do
    increment_build_number(
      xcodeproj: "Alma.App.Oficial.xcodeproj"
    )
    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id:                          ENV["APPLE_ID"]
    )
  end

  desc "Build and submit to App Store"
  lane :release do
    increment_build_number(
      xcodeproj: "Alma.App.Oficial.xcodeproj"
    )
    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )
    upload_to_app_store(
      skip_metadata:         false,
      skip_screenshots:      false,
      submit_for_review:     false,
      automatic_release:     false,
      metadata_path:         "./fastlane/metadata/ios",
      screenshots_path:      "./fastlane/screenshots/ios"
    )
  end

end

# ══ Android ═══════════════════════════════════════════════════════════════════

platform :android do

  desc "Build and upload to Google Play Internal track"
  lane :beta do
    gradle(
      task:            "bundle",
      build_type:      "Release",
      project_dir:     "android",
      properties: {
        "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["ANDROID_STORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
    upload_to_play_store(
      track:        "internal",
      aab:          "android/app/build/outputs/bundle/release/app-release.aab",
      package_name: "AlmaOficial.Alma"
    )
  end

  desc "Promote Internal → Production on Google Play"
  lane :release do
    upload_to_play_store(
      track:              "internal",
      track_promote_to:   "production",
      package_name:       "AlmaOficial.Alma"
    )
  end

end
