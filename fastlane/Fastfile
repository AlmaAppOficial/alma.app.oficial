# ─────────────────────────────────────────────────────────────────────────────
#  Fastfile — Alma App automation
#
#  Usage:
#    bundle exec fastlane ios ci_beta       → CI: build + TestFlight (p12 cert)
#    bundle exec fastlane ios beta          → build + TestFlight
#    bundle exec fastlane ios release       → build + App Store
#    bundle exec fastlane android beta      → build + Play Internal
#    bundle exec fastlane android release   → build + Play Production
# ─────────────────────────────────────────────────────────────────────────────

require 'base64'

default_platform(:ios)

# ══ iOS ═════════════════════════════════════════════════════════════════════════════

platform :ios do

  desc "CI: Build and upload to TestFlight using .p12 certificate from env"
  lane :ci_beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILE"],
      duration:     1200,
      in_house:     false
    )

    # Write p12 from env var to temp file
    p12_path = "/tmp/distribution_cert.p12"
    File.write(p12_path, Base64.decode64(ENV["CERTIFICATE_BASE64"]))
    import_certificate(
      certificate_path:     p12_path,
      certificate_password: ENV["CERTIFICATE_PASSWORD"],
      keychain_name:        "fastlane_tmp_keychain",
      keychain_password:    ""
    )

    sigh(
      api_key:        api_key,
      app_identifier: "com.almaapp.app",
      force:          true,
      output_path:    "/tmp/fastlane_profiles"
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "Alma.App.Oficial.xcodeproj"
    )

    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      project:     "Alma.App.Oficial.xcodeproj",
      scheme:      "Alma.App.Oficial (iOS)",
      destination: "platform=iOS Simulator,name=iPhone 15"
    )
  end

  desc "Build and upload to TestFlight (beta)"
  lane :beta do
    increment_build_number(
      xcodeproj: "Alma.App.Oficial.xcodeproj"
    )
    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id:                          ENV["APPLE_ID"]
    )
  end

  desc "Build and submit to App Store"
  lane :release do
    increment_build_number(
      xcodeproj: "Alma.App.Oficial.xcodeproj"
    )
    build_ios_app(
      project:           "Alma.App.Oficial.xcodeproj",
      scheme:            "Alma.App.Oficial (iOS)",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Alma.ipa"
    )
    upload_to_app_store(
      skip_metadata:         false,
      skip_screenshots:      false,
      submit_for_review:     false,
      automatic_release:     false,
      metadata_path:         "./fastlane/metadata/ios",
      screenshots_path:      "./fastlane/screenshots/ios"
    )
  end

end

# ══ Android ═════════════════════════════════════════════════════════════════════════════

platform :android do

  desc "Build and upload to Google Play Internal track"
  lane :beta do
    gradle(
      task:            "bundle",
      build_type:      "Release",
      project_dir:     "android",
      properties: {
        "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["ANDROID_STORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
    upload_to_play_store(
      track:        "internal",
      aab:          "android/app/build/outputs/bundle/release/app-release.aab",
      package_name: "AlmaOficial.Alma"
    )
  end

  desc "Promote Internal → Production on Google Play"
  lane :release do
    upload_to_play_store(
      track:              "internal",
      track_promote_to:   "production",
      package_name:       "AlmaOficial.Alma"
    )
  end

end
